# Base App Config
ENVIRONMENT=production
PORT=8000
FRONTEND_URL=https://my-journal-8c171.web.app
ENV_PATH=.env

# SMTP Config (for sending OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-smtp-app-password

# Firebase & Storage Config
GOOGLE_STORAGE_BUCKET=my-journal-8c171.firebasestorage.app
# Note: GOOGLE_APPLICATION_CREDENTIALS is not required in Firebase Functions production environment

# APIs & Security
GEMINI_API_KEY=your-gemini-api-key
JWT_SECRET=your-secure-jwt-secret-key-for-production
JWT_ALGORITHM=HS256
